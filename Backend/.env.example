# ── Auth / Security ──────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-in-production
# JWT_ALGORITHM=HS256
# JWT_EXPIRATION_MINUTES=10080

# ── Database ─────────────────────────────────────────────────────────────────
# DATABASE_URL=sqlite:///./shikaar.db

# ── Gemini LLM ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# ── Paths (defaults work out of the box) ─────────────────────────────────────
# DATA_DIR=data/cab_knowledge
# VECTOR_DB_DIR=vector_db

# ── Chunking ─────────────────────────────────────────────────────────────────
# CHUNK_SIZE=500
# CHUNK_OVERLAP=100

# ── Retriever ────────────────────────────────────────────────────────────────
# RETRIEVER_K=10
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Pagination ───────────────────────────────────────────────────────────────
# DEFAULT_PAGE_SIZE=3
